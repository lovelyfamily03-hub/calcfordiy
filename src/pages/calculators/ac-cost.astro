<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function isChecked(id) {
    return document.getElementById(id).checked;
  }

  function toggleSection(sectionId, show) {
    document.getElementById(sectionId).classList.toggle('hidden', !show);
    calculate();
  }

  function applyBtuPreset() {
    var val = document.getElementById('btu_preset').value;
    if (val) {
      document.getElementById('btu').value = val;
      calculate();
    }
  }

  function applyHoursPreset() {
    var val = document.getElementById('hours_preset').value;
    if (val) {
      document.getElementById('hours_per_day').value = val;
      calculate();
    }
  }

  function applySeasonPreset() {
    var val = document.getElementById('season_preset').value;
    if (val) {
      document.getElementById('season_months').value = val;
      calculate();
    }
  }

  function applyUnitType() {
    var type = document.getElementById('unit_type').value;
    var hint = document.getElementById('seer_hint');
    if (type === 'central') {
      hint.textContent = 'Older units: 8-10 SEER. Federal minimum 2023: 14 SEER. High efficiency: 18-25 SEER.';
    } else if (type === 'window') {
      hint.textContent = 'Window units use EER not SEER. Enter EER rating from label. Typical: 8-12 EER.';
    } else if (type === 'mini') {
      hint.textContent = 'Mini-splits are very efficient. Typical: 18-30+ SEER. Check EnergyGuide label.';
    } else if (type === 'portable') {
      hint.textContent = 'Portable units are least efficient. Typical: 8-10 SEER equivalent (CEER rating).';
    }
    calculate();
  }

  function calcCost(btu, seer, hoursPerDay, months, rate) {
    // Power in kW = BTU / (SEER × 1000)
    // This is the standard formula: SEER = BTU cooling output / watt-hours input
    var kw = btu / (seer * 1000);
    var costPerHour = kw * rate;
    var costPerDay = costPerHour * hoursPerDay;
    var costPerMonth = costPerDay * 30.4;
    var costPerSeason = costPerDay * (months * 30.4);

    return {
      kw: kw,
      costPerHour: costPerHour,
      costPerMonth: costPerMonth,
      costPerSeason: costPerSeason
    };
  }

  function calculate() {
    var btu = getNum('btu');
    var seer = getNum('seer');
    var hoursPerDay = getNum('hours_per_day');
    var months = getNum('season_months');
    var rate = getNum('rate');

    document.getElementById('errorMsg').classList.add('hidden');

    if (btu <= 0 || seer <= 0 || hoursPerDay <= 0 || months <= 0 || rate <= 0) {
      document.getElementById('results').classList.add('hidden');
      document.getElementById('printBtn').classList.add('hidden');
      if (btu > 0 || seer > 0) document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    var result = calcCost(btu, seer, hoursPerDay, months, rate);

    var tons = (btu / 12000).toFixed(1);
    var breakdown = (btu / 1000).toFixed(1) + ' BTU (' + tons + ' ton) at SEER ' + seer +
      ' draws ' + (result.kw * 1000).toFixed(0) + ' watts (' + result.kw.toFixed(3) + ' kW). ' +
      'At $' + rate + '/kWh running ' + hoursPerDay + ' hours/day: $' +
      result.costPerHour.toFixed(3) + '/hour × ' + hoursPerDay + ' hrs = $' +
      (result.costPerHour * hoursPerDay).toFixed(2) + '/day.';

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    
    document.getElementById('r_kw').textContent = result.kw.toFixed(3) + ' kW';
    document.getElementById('r_hourly').textContent = '$' + result.costPerHour.toFixed(3);
    document.getElementById('r_monthly').textContent = '$' + result.costPerMonth.toFixed(2);
    document.getElementById('r_seasonal').textContent = '$' + result.costPerSeason.toFixed(2) + '/yr';
    document.getElementById('r_breakdown').textContent = breakdown;

    var compResults = document.getElementById('comparisonResults');
    if (isChecked('compareToggle')) {
      var newSeer = getNum('new_seer');
      var installCost = getNum('install_cost');

      if (newSeer > 0) {
        var newResult = calcCost(btu, newSeer, hoursPerDay, months, rate);
        var annualSavings = result.costPerSeason - newResult.costPerSeason;
        var paybackText = '—';

        if (installCost > 0 && annualSavings > 0) {
          var paybackYears = installCost / annualSavings;
          paybackText = paybackYears.toFixed(1) + ' years';
        } else if (annualSavings <= 0) {
          paybackText = 'No savings at this SEER';
        } else {
          paybackText = 'Enter cost for payback';
        }

        compResults.classList.remove('hidden');
        document.getElementById('r_current_seasonal').textContent = '$' + result.costPerSeason.toFixed(2);
        document.getElementById('r_new_seasonal').textContent = '$' + newResult.costPerSeason.toFixed(2);
        document.getElementById('r_savings').textContent = annualSavings > 0
          ? '$' + annualSavings.toFixed(2) + ' saved'
          : '$' + Math.abs(annualSavings).toFixed(2) + ' more';
        document.getElementById('r_payback').textContent = paybackText;
      } else {
        compResults.classList.add('hidden');
      }
    } else {
      compResults.classList.add('hidden');
    }
    
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('unit_type').addEventListener('change', applyUnitType);
    document.getElementById('rate').value = '0.16';
    document.getElementById('hours_per_day').value = '8';
    document.getElementById('season_months').value = '5';
    document.getElementById('seer').value = '14';
  });
</script>