    let totalRunning = 0;
    let highestSurge = 0;
    let highestSurgeName = "None";
    let selectedCount = 0;

    // Standard items
    const standardCheckboxes = document.querySelectorAll('.app-checkbox');
    standardCheckboxes.forEach(cb => {
      if (cb.checked) {
        selectedCount++;
        const run = parseInt(cb.dataset.run) || 0;
        const surge = parseInt(cb.dataset.surge) || 0;
        const name = cb.dataset.name;
        
        totalRunning += run;
        if (surge > highestSurge) {
          highestSurge = surge;
          highestSurgeName = name;
        }
      }
    });

    // Custom items
    for(let i=1; i<=2; i++) {
      const cb = document.getElementById('cbox_' + i);
      if (cb && cb.checked) {
        selectedCount++;
        const run = parseInt(document.getElementById('crun_' + i).value) || 0;
        const surge = parseInt(document.getElementById('csurge_' + i).value) || 0;
        let name = document.getElementById('cname_' + i).value;
        if (!name || name.trim() === '') name = "Custom Item " + i;
        
        totalRunning += run;
        if (surge > highestSurge) {
          highestSurge = surge;
          highestSurgeName = name;
        }
      }
    }

    if (selectedCount === 0) {
      document.getElementById('errorMsg').classList.remove('hidden');
      document.getElementById('results').classList.add('hidden');
      return;
    }
    
    document.getElementById('errorMsg').classList.add('hidden');

    // Math
    const subtotal = totalRunning + highestSurge;
    const recommendedGenerator = Math.ceil(subtotal * 1.20); // 20% safety margin

    document.getElementById('r_run').innerText = totalRunning;
    document.getElementById('r_surge').innerText = highestSurge;
    document.getElementById('r_total').innerText = recommendedGenerator.toLocaleString();

    let noteHtml = `<strong>Formula Breakdown:</strong> We summed your total running load (${totalRunning}W) and added ONLY your single highest surge requirement from the <strong>${highestSurgeName}</strong> (${highestSurge}W). `;
    noteHtml += `Finally, we added a 20% safety margin to prevent your generator from continuously running at 100% capacity, which burns excess fuel and shortens engine life.`;
    
    document.getElementById('calc_note').innerHTML = noteHtml;

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    document.getElementById('printBtn').classList.add('flex');
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('calcBtn').addEventListener('click', calculate);
    
    // Auto trigger calc if results are visible and a checkbox is toggled
    const allCheckboxes = document.querySelectorAll('input[type="checkbox"]');
    allCheckboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        if (!document.getElementById('results').classList.contains('hidden')) {
          calculate();
        }
      });
    });
  });
</script>
