---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Hardwood Flooring Calculator — How Many Boxes Do I Need? | CalcForDIY"
  description="Calculate how many boxes of hardwood flooring you need. Enter room dimensions, installation angle, and box coverage for an instant estimate with waste included. Free, no signup."
>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Hardwood Flooring Calculator",
    "description": "Free hardwood flooring calculator that estimates how many boxes you need including waste factor for your installation direction.",
    "applicationCategory": "CalculatorApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://calcfordiy.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Hardwood Flooring Calculator",
        "item": "https://calcfordiy.com/calculators/hardwood-flooring"
      }
    ]
  }
  </script>
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <span>Hardwood Flooring Calculator</span>
  </div>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Hardwood Flooring Calculator</h1>
    <p class="text-gray-600 text-lg">Enter your room dimensions to find out how many boxes of hardwood flooring to buy — waste factor included based on your installation direction.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold">1</span>
      Room Dimensions
    </h2>

    <div class="p-4 bg-gray-50 rounded-lg mb-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Room Length</label>
          <div class="flex items-center gap-2">
            <input type="number" id="r_len_ft" placeholder="14" min="0" max="200"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">ft</span>
            <input type="number" id="r_len_in" placeholder="0" min="0" max="11"
              class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">in</span>
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Room Width</label>
          <div class="flex items-center gap-2">
            <input type="number" id="r_wid_ft" placeholder="12" min="0" max="200"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">ft</span>
            <input type="number" id="r_wid_in" placeholder="0" min="0" max="11"
              class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">in</span>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-xs text-gray-500 mb-1">Number of identical rooms</label>
        <div class="flex items-center gap-3">
          <input type="number" id="num_rooms" value="1" min="1" max="50"
            class="w-24 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-xs text-gray-400">Multiply if doing several same-size rooms</span>
        </div>
      </div>
    </div>

    <div class="mb-5">
      <label class="flex items-center gap-2 cursor-pointer p-3 rounded-lg border border-dashed border-gray-300 hover:bg-gray-50">
        <input type="checkbox" id="subtractToggle" class="w-4 h-4 rounded text-blue-600" onchange="toggleSection('subtractSection', this.checked)" />
        <span class="text-sm text-gray-700">Subtract an area (closet, hearth, built-in)</span>
      </label>
      <div id="subtractSection" class="hidden mt-3 p-4 bg-gray-50 rounded-lg">
        <p class="text-xs text-gray-500 mb-3">Dimensions of any area within the room that will NOT be floored.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Area Length</label>
            <div class="flex items-center gap-2">
              <input type="number" id="sub_len_ft" placeholder="0" min="0" max="100"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">ft</span>
              <input type="number" id="sub_len_in" placeholder="0" min="0" max="11"
                class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">in</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Area Width</label>
            <div class="flex items-center gap-2">
              <input type="number" id="sub_wid_ft" placeholder="0" min="0" max="100"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">ft</span>
              <input type="number" id="sub_wid_in" placeholder="0" min="0" max="11"
                class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">in</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <hr class="my-5 border-gray-200" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold">2</span>
      Flooring Settings
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Installation Direction</label>
        <select id="direction"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="straight">Straight / Parallel (7% waste)</option>
          <option value="diagonal">Diagonal (10% waste)</option>
        </select>
        <p class="text-xs text-gray-400 mt-1">Hardwood uses lower waste than laminate per NWFA guidelines</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Box Coverage <span class="text-gray-400 font-normal text-xs">(from your flooring box)</span>
        </label>
        <div class="flex items-center gap-2">
          <input type="number" id="boxCoverage" placeholder="e.g. 18.5" min="0.1" step="0.1"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-sm text-gray-500 shrink-0">sq ft / box</span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Leave blank to skip box count</p>
      </div>
    </div>

    <button onclick="calculate()"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors text-base">
      Calculate Boxes Needed →
    </button>

  </div>

  <div id="errorMsg" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-red-700 text-sm">
    Please enter your room length and width to calculate.
  </div>

  <div id="results" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 mb-8">
    <h2 class="text-lg font-semibold text-blue-900 mb-4">Your Flooring Estimate</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-gray-900" id="r_area">—</div>
        <div class="text-xs text-gray-500 mt-1">Net Floor Area</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-blue-700" id="r_waste">—</div>
        <div class="text-xs text-gray-500 mt-1">Waste Factor</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-gray-900" id="r_total">—</div>
        <div class="text-xs text-gray-500 mt-1">Total to Buy</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm" id="r_boxRow">
        <div class="text-2xl font-bold text-green-700" id="r_boxes">—</div>
        <div class="text-xs text-gray-500 mt-1">Boxes Needed</div>
      </div>
    </div>
    <p class="text-xs text-blue-800 mt-4 bg-blue-200 bg-opacity-50 rounded-lg p-3">
      <strong>Tip:</strong> Keep one box of leftover hardwood. Wood flooring expands and contracts seasonally — having matching boards for future repairs is valuable.
    </p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">How to Use This Calculator</h2>
    <p class="text-gray-700 mb-4">Follow these steps to get an accurate estimate from this hardwood flooring calculator:</p>
    <ol class="space-y-4 text-gray-700">
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
        <span><strong>Measure the room.</strong> Enter the maximum length and width of your room in feet and inches.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
        <span><strong>Multiply identical rooms.</strong> If you are flooring multiple rooms of the exact same size, increase the room count.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
        <span><strong>Subtract unfloored areas.</strong> Enter the dimensions of any closets, hearths, or built-in cabinets that will not receive flooring to subtract them from the total.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">4</span>
        <span><strong>Select installation direction.</strong> Choose a straight or diagonal layout. This adjusts the waste factor automatically.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">5</span>
        <span><strong>Enter box coverage.</strong> Check your flooring box label for the square footage it covers to get a precise box count.</span>
      </li>
    </ol>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">The Formula</h2>
    <p class="text-gray-700 mb-4">This hardwood flooring calculator uses specific waste guidelines to ensure you buy exactly what you need. Here is the math:</p>
    <div class="bg-gray-50 rounded-lg p-4 mb-5 font-mono text-sm text-gray-800 space-y-1">
      <p>Net Area = (Room Area − Subtracted Areas) × Number of Rooms</p>
      <p>Total to Buy (Straight) = Net Area × 1.07</p>
      <p>Total to Buy (Diagonal) = Net Area × 1.10</p>
      <p>Boxes Needed = Math.ceil(Total to Buy / Box Coverage)</p>
    </div>
    <p class="text-gray-700">The net area equals the total room area minus any subtracted areas, multiplied by the number of rooms. To find the total to buy, the net area is multiplied by 1.07 for a straight installation (adding 7% waste) or 1.10 for a diagonal installation (adding 10% waste). Finally, the total is divided by your box coverage and rounded up to the nearest whole box. Hardwood uses 7% waste for straight installs and 10% for diagonal—lower than laminate's 10% and 15%. This comes directly from National Wood Flooring Association (NWFA) installation guidelines and reflects that hardwood planks are longer and produce less cut waste than shorter laminate planks. That distinction makes this tool more accurate than generic flooring calculators that use one flat rate for all materials.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-5">
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Why does hardwood need less waste than laminate?</h3>
        <p class="text-gray-600 text-sm">Hardwood planks are typically longer and have varied lengths inside the box. This allows installers to easily reuse offcuts at the start of a new row, producing significantly less cut waste than uniform, shorter laminate planks.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Should I include closets in the measurement?</h3>
        <p class="text-gray-600 text-sm">Yes, if you plan to extend the hardwood seamlessly into the closet. Treat the closet as part of the main room's dimensions, or calculate it as a separate space and add it to your total using a hardwood flooring calculator.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">How do I handle L-shaped rooms?</h3>
        <p class="text-gray-600 text-sm">Break the L-shape into two separate rectangles. Measure the length and width of each rectangle, calculate their square footage separately, and add them together to get your total room area.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Does engineered hardwood use the same calculation?</h3>
        <p class="text-gray-600 text-sm">Yes. Engineered hardwood installs much like solid hardwood and comes in similar plank lengths. You should use the same 7% waste factor for straight installations and 10% for diagonal layouts.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">What should I do if I run short mid-project?</h3>
        <p class="text-gray-600 text-sm">Stop installing immediately and order more wood from the exact same manufacturer and mill run. Wood is a natural product; buying a new batch weeks later often results in noticeable color, grain, or milling variations.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Does installation direction affect the look of the room?</h3>
        <p class="text-gray-600 text-sm">Absolutely. Running planks parallel to the longest wall makes a room look larger. Running them diagonally draws the eye outward to the corners, making narrow spaces feel wider, but requires more complex cuts and a higher waste factor.</p>
      </div>
    </div>
  </div>

  <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Calculators</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <a href="/calculators/laminate-flooring" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Laminate Flooring Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Calculate laminate flooring needs with standard 10% waste.</div>
      </a>
      <a href="/calculators/underlayment" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Underlayment Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Figure out exactly how many rolls of padding to buy.</div>
      </a>
      <a href="/calculators/carpet" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Carpet Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Estimate carpet and padding in square yards for any room.</div>
      </a>
    </div>
  </div>

</Layout>

<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function toFt(ftId, inId) {
    return getNum(ftId) + getNum(inId) / 12;
  }

  function isChecked(id) {
    return document.getElementById(id).checked;
  }

  function toggleSection(sectionId, show) {
    document.getElementById(sectionId).classList.toggle('hidden', !show);
    calculate();
  }

  function calculate() {
    var len = toFt('r_len_ft', 'r_len_in');
    var wid = toFt('r_wid_ft', 'r_wid_in');
    var rooms = Math.max(1, getNum('num_rooms') || 1);

    document.getElementById('errorMsg').classList.add('hidden');

    if (len <= 0 || wid <= 0) {
      document.getElementById('results').classList.add('hidden');
      if (len > 0 || wid > 0) document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    var netArea = len * wid * rooms;

    if (isChecked('subtractToggle')) {
      var subLen = toFt('sub_len_ft', 'sub_len_in');
      var subWid = toFt('sub_wid_ft', 'sub_wid_in');
      netArea -= subLen * subWid;
    }

    if (netArea <= 0) {
      document.getElementById('results').classList.add('hidden');
      document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    var direction = document.getElementById('direction').value;
    var wasteMap = { straight: 0.07, diagonal: 0.10 };
    var waste = wasteMap[direction] || 0.07;
    var totalToBuy = netArea * (1 + waste);

    var boxCoverage = getNum('boxCoverage');
    var boxesNeeded = boxCoverage > 0 ? Math.ceil(totalToBuy / boxCoverage) : null;

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('r_area').textContent = netArea.toFixed(1) + ' sq ft';
    document.getElementById('r_waste').textContent = (waste * 100) + '%';
    document.getElementById('r_total').textContent = totalToBuy.toFixed(1) + ' sq ft';

    if (boxesNeeded !== null) {
      document.getElementById('r_boxes').textContent = boxesNeeded + ' boxes';
      document.getElementById('r_boxRow').classList.remove('hidden');
    } else {
      document.getElementById('r_boxRow').classList.add('hidden');
    }

    
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('direction').addEventListener('change', calculate);
  });
</script>