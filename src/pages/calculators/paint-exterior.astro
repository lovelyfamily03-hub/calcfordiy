<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function toFt(ftId, inId) {
    return getNum(ftId) + getNum(inId) / 12;
  }

  function isChecked(id) {
    return document.getElementById(id).checked;
  }

  function toggleSection(sectionId, show) {
    document.getElementById(sectionId).classList.toggle('hidden', !show);
    calculate();
  }

  function wallArea(widFtId, widInId, hgtFtId, hgtInId) {
    return toFt(widFtId, widInId) * toFt(hgtFtId, hgtInId);
  }

  function calculate() {
    var grossArea = 0;
    var hasInput = false;

    var a1 = wallArea('w1_wid_ft', 'w1_wid_in', 'w1_hgt_ft', 'w1_hgt_in');
    var a2 = wallArea('w2_wid_ft', 'w2_wid_in', 'w2_hgt_ft', 'w2_hgt_in');
    var a3 = wallArea('w3_wid_ft', 'w3_wid_in', 'w3_hgt_ft', 'w3_hgt_in');
    var a4 = wallArea('w4_wid_ft', 'w4_wid_in', 'w4_hgt_ft', 'w4_hgt_in');

    grossArea = a1 + a2 + a3 + a4;
    if (grossArea > 0) hasInput = true;

    // Gable ends
    if (isChecked('gableToggle')) {
      var gabWid = getNum('gab_wid_ft');
      var gabHgt = getNum('gab_hgt_ft');
      var numGables = Math.max(1, getNum('num_gables') || 2);
      grossArea += 0.5 * gabWid * gabHgt * numGables;
    }

    document.getElementById('errorMsg').classList.add('hidden');

    if (!hasInput || grossArea <= 0) {
      document.getElementById('results').classList.add('hidden');
      document.getElementById('printBtn').classList.add('hidden');
      return;
    }

    // Subtract openings
    var doors = getNum('num_doors');
    var windows = getNum('num_windows');
    var garageDoors = getNum('num_garage_doors');
    var netArea = grossArea - (doors * 21) - (windows * 15) - (garageDoors * 160);
    netArea = Math.max(netArea, 0);

    var coverage = parseFloat(document.getElementById('siding').value) || 350;
    var coats = parseInt(document.getElementById('coats').value) || 2;
    var includeTrim = document.getElementById('trim').value === 'yes';
    var shutters = getNum('num_shutters');

    var bodyGallons = (netArea * coats) / coverage;

    // Trim: 10% of body area at 400 sq ft/gal coverage (smooth trim)
    var trimArea = netArea * 0.10;
    // Add shutter area
    trimArea += shutters * 6;
    var trimGallons = includeTrim ? (trimArea * coats) / 400 : 0;

    var totalGallons = bodyGallons + trimGallons;

    function buyingGuide(gallons, label) {
      var rounded = Math.ceil(gallons);
      if (rounded <= 5) return label + ': ' + rounded + ' × 1-gallon cans';
      var fiveGal = Math.floor(rounded / 5);
      var oneGal = rounded % 5;
      var guide = label + ': ' + fiveGal + ' × 5-gallon bucket' + (fiveGal > 1 ? 's' : '');
      if (oneGal > 0) guide += ' + ' + oneGal + ' × 1-gallon can' + (oneGal > 1 ? 's' : '');
      return guide;
    }

    var buyingText = buyingGuide(bodyGallons, 'Body paint');
    if (includeTrim) buyingText += '. ' + buyingGuide(trimGallons, 'Trim paint');

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    
    document.getElementById('r_gross_area').textContent = grossArea.toFixed(0) + ' sq ft';
    document.getElementById('r_net_area').textContent = netArea.toFixed(0) + ' sq ft';
    document.getElementById('r_body_gal').textContent = Math.ceil(bodyGallons) + ' gal';
    document.getElementById('r_total_gal').textContent = Math.ceil(totalGallons) + ' gal';
    document.getElementById('r_buying').textContent = buyingText;

    var trimRow = document.getElementById('trimRow');
    if (includeTrim) {
      document.getElementById('r_trim_gal').textContent = Math.ceil(trimGallons) + ' gal';
      trimRow.classList.remove('hidden');
    } else {
      trimRow.classList.add('hidden');
    }
    
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('siding').addEventListener('change', calculate);
    document.getElementById('coats').addEventListener('change', calculate);
    document.getElementById('trim').addEventListener('change', calculate);
  });
</script>
