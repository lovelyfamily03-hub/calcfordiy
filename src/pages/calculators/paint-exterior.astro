        </div>
      </div>

      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-sm font-medium text-gray-700 mb-3">Wall 3 (Left Side)</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Width (depth of house)</label>
            <div class="flex items-center gap-2">
              <input type="number" id="w3_wid_ft" placeholder="30" min="0" max="500"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">ft</span>
              <input type="number" id="w3_wid_in" placeholder="0" min="0" max="11"
                class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">in</span>
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Height</label>
            <div class="flex items-center gap-2">
              <input type="number" id="w3_hgt_ft" placeholder="10" min="0" max="60"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">ft</span>
              <input type="number" id="w3_hgt_in" placeholder="0" min="0" max="11"
                class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
              <span class="text-xs text-gray-500 shrink-0">in</span>
            </div>
          </div>
        </div>
      </div>

      <div class="p-4 bg-gray-50 rounded-lg">
        <p class="text-sm font-medium text-gray-700 mb-3">Wall 4 (Right Side)</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">Width (depth of house)</label>
            <div class="flex items-center gap-2">
              <input type="number" id="w4_wid_ft" placeholder="30" min="0" max="500"
