<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function toFt(ftId, inId) {
    return getNum(ftId) + getNum(inId) / 12;
  }

  function rectArea(hFtId, hInId, wFtId, wInId) {
    return toFt(hFtId, hInId) * toFt(wFtId, wInId);
  }

  function isChecked(id) {
    return document.getElementById(id).checked;
  }

  function toggleSection(sectionId, show) {
    document.getElementById(sectionId).classList.toggle('hidden', !show);
    calculate();
  }

  function calculate() {
    var totalArea = 0;
    var hasInput = false;

    var a1 = rectArea('w1h_ft', 'w1h_in', 'w1w_ft', 'w1w_in');
    totalArea += a1;
    if (a1 > 0) hasInput = true;

    var a2 = rectArea('w2h_ft', 'w2h_in', 'w2w_ft', 'w2w_in');
    totalArea += a2;
    if (a2 > 0) hasInput = true;

    if (isChecked('wall3Toggle')) totalArea += rectArea('w3h_ft', 'w3h_in', 'w3w_ft', 'w3w_in');
    if (isChecked('wall4Toggle')) totalArea += rectArea('w4h_ft', 'w4h_in', 'w4w_ft', 'w4w_in');

    if (isChecked('floorToggle')) {
      var floorA = rectArea('fl_ft', 'fl_in', 'fw_ft', 'fw_in');
      totalArea += floorA;
      if (floorA > 0) hasInput = true;
    }

    if (isChecked('doorToggle')) totalArea -= rectArea('dh_ft', 'dh_in', 'dw_ft', 'dw_in');
    if (isChecked('windowToggle')) totalArea -= rectArea('wh_ft', 'wh_in', 'ww_ft', 'ww_in');
    if (isChecked('nicheToggle')) totalArea -= rectArea('nh_ft', 'nh_in', 'nw_ft', 'nw_in');

    document.getElementById('errorMsg').classList.add('hidden');

    if (!hasInput || totalArea <= 0) {
      document.getElementById('results').classList.add('hidden');
      if (hasInput && totalArea <= 0) document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    var pattern = document.getElementById('pattern').value;
    var wasteMap = { straight: 0.10, diagonal: 0.15, herringbone: 0.20 };
    var waste = wasteMap[pattern] || 0.10;
    var totalWithWaste = totalArea * (1 + waste);

    var boxCoverage = getNum('boxCoverage');
    var boxesNeeded = boxCoverage > 0 ? Math.ceil(totalWithWaste / boxCoverage) : null;

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('r_totalArea').textContent = totalArea.toFixed(1) + ' sq ft';
    document.getElementById('r_waste').textContent = (waste * 100) + '%';
    document.getElementById('r_totalWithWaste').textContent = totalWithWaste.toFixed(1) + ' sq ft';

    if (boxesNeeded !== null) {
      document.getElementById('r_boxes').textContent = boxesNeeded + ' boxes';
      document.getElementById('r_boxRow').classList.remove('hidden');
    } else {
      document.getElementById('r_boxRow').classList.add('hidden');
    }

    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('pattern').addEventListener('change', calculate);
  });
</script>
