const categories = [...new Set(calculators.map(c => c.category))];
---

<Layout
  title="Free DIY Calculators — CalcForDIY"
  description="Free calculators for home improvement projects. Tile, flooring, lighting, and more. No signup, no uploads, instant results."
>
<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CalcForDIY",
  "url": "https://calcfordiy.com",
  "description": "Free calculators for home improvement projects including tile, flooring, and lighting.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://calcfordiy.com/?s={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
  <div class="mb-10">
    <h1 class="text-4xl font-bold text-gray-900 mb-3">Free DIY Calculators</h1>
    <p class="text-lg text-gray-600">
      Instant, accurate calculators for home improvement projects. 
      No account needed. Everything runs in your browser.
    </p>
  </div>

  <div class="flex flex-col gap-4">
    {categories.map(category => (
      <details class="group bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
        <summary class="flex items-center justify-between cursor-pointer p-6 bg-white hover:bg-gray-50 transition-colors list-none [&::-webkit-details-marker]:hidden">
          <h2 class="text-xl font-bold text-gray-900">{category} Calculators</h2>
          
          <span class="flex items-center gap-3">
            <span class="text-sm font-medium text-gray-400 bg-gray-100 px-3 py-1 rounded-full group-open:hidden">
              {calculators.filter(c => c.category === category).length} tools
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
        </summary>
        
        <div class="p-6 border-t border-gray-200 bg-gray-50">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {calculators
              .filter(c => c.category === category)
              .map(calc => (
                <a
                  href={calc.href}
                  class="block p-5 bg-white rounded-xl border border-gray-200 hover:border-blue-500 hover:shadow-md transition-all flex flex-col h-full"
                >
                  <h3 class="font-semibold text-gray-900 mb-2">{calc.title}</h3>
                  <p class="text-sm text-gray-600 flex-grow">{calc.description}</p>
                  <span class="inline-block mt-4 text-sm text-blue-600 font-semibold group-hover:text-blue-700">
                    Use calculator →
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </details>
    ))}
  </div>

  <div class="mt-12 bg-white border border-gray-200 rounded-xl p-8 shadow-sm">
    <h2 class="text-2xl font-bold text-gray-900 mb-4">About These Calculators</h2>
    <div class="space-y-4 text-gray-700">
      <p>Every calculator on CalcForDIY runs entirely in your browser. Nothing is uploaded to a server. No account needed. Results are instant.</p>
      <p>All formulas are sourced from industry standards — the Tile Council of North America for tile waste factors, the National Wood Flooring Association for hardwood and laminate, and manufacturer technical documentation from Mapei and LATICRETE for grout calculations.</p>
      <p>Whether you are a first-time DIYer or a contractor running quick estimates on a job site, these tools are built to give you accurate numbers fast.</p>
    </div>
  </div>
</Layout>
