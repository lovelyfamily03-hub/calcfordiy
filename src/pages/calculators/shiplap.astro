        <div class="text-2xl font-bold text-gray-900 print:text-3xl" id="r_linear">—</div>
        <div class="text-xs text-gray-500 mt-1">Linear Feet Needed</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm border-2 border-green-400 print:border-gray-400 print:shadow-none">
        <div class="text-2xl font-bold text-green-700 print:text-3xl print:text-gray-900"><span id="r_coverage">—</span></div>
        <div class="text-xs text-gray-700 font-medium mt-1">True Coverage Face</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm border-2 border-blue-400 print:border-gray-400 print:shadow-none">
        <div class="text-2xl font-bold text-blue-700 print:text-3xl print:text-gray-900" id="r_boards">—</div>
        <div class="text-xs text-gray-700 font-medium mt-1">Total Boards to Buy</div>
      </div>
    </div>
    
    <p id="calc_note" class="text-xs text-blue-800 mt-4 bg-blue-200 bg-opacity-50 rounded-lg p-3 print:bg-gray-100 print:text-gray-700 print:border print:border-gray-200">
      <!-- Injected by JS -->
    </p>

    <button id="printBtn" onclick="window.print()" class="hidden mt-5 w-full bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 px-6 rounded-lg transition-colors print:hidden text-base flex justify-center items-center gap-2">
      🖨️ Print or Save as PDF
    </button>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6 print:hidden">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">How to Use This Calculator</h2>
    <p class="text-gray-700 mb-4">Buying shiplap by looking at the board's width at the hardware store is the most common mistake DIYers make. Follow these steps to get an accurate count.</p>
    <ol class="space-y-4 text-gray-700">
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
        <span><strong>Select your board profile.</strong> A 1x6 board is 5.5 inches wide, but about 1/2 inch is lost in the overlap (rabbet or tongue). The actual face that covers the wall is only 4 7/8". We calculate the math using the true exposed face so you do not run short.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
        <span><strong>Select your gap.</strong> If you are installing raw boards and spacing them manually with a nickel, choose "Nickel Gap". This adds 1/8" to your coverage per board. If you bought pre-milled boards that auto-space themselves, leave it on "Flush" because the gap is already accounted for in the milling.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
        <span><strong>Measure your walls and subtract openings.</strong> Enter the height and width of your walls. If you have large doors or windows, toggle the subtract buttons and enter their dimensions so you do not over-buy lumber.</span>
      </li>
    </ol>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6 print:hidden">
    <h2 class="text-xl font-semibold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-5">
      <div>
        <h3 class="font-bold text-gray-900 mb-1">What is the true exposed face of shiplap?</h3>
        <p class="text-gray-600 text-sm">A standard 1x6 shiplap board measures 5.5 inches wide at the store, but the actual exposed face (coverage) is only about 4 7/8 inches (often rounded to 5 inches) because the rabbet edges overlap when installed. If you calculate your wall using the 5.5-inch dimension, you will not buy enough wood.</p>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">What size is a nickel gap?</h3>
        <p class="text-gray-600 text-sm">A true nickel gap spacing is 1/8 of an inch. Many modern shiplap boards are milled so the face automatically leaves a 1/8-inch gap when the boards are stacked tight. If you are using raw square-edge boards, you can physically use nickels (or 1/8-inch tile spacers) to create this look.</p>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Should I install shiplap horizontally or vertically?</h3>
        <p class="text-gray-600 text-sm">Horizontal shiplap makes a room feel wider and is the traditional farmhouse look. Vertical shiplap draws the eye up, making ceilings feel taller, and leans toward a modern or mid-century aesthetic. Neither affects the square footage needed, but vertical installations may result in slightly more waste if the wall height doesn't divide evenly into the board length.</p>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Why is my board count multiplied by a waste factor?</h3>
        <p class="text-gray-600 text-sm">We automatically add a standard 10% waste factor to your final board count. This accounts for inevitable off-cuts at the ends of walls, mistakes, and occasionally finding a board in your pile that is too warped or knotted to use.</p>
      </div>
    </div>
  </div>

  <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 print:hidden">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Calculators</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <a href="/calculators/drywall" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Drywall Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Calculate sheetrock counts for your walls if you need a backer behind your shiplap.</div>
      </a>
      <a href="/calculators/trim-molding" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Trim & Molding Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Calculate baseboard material needs, including miter corner waste logic.</div>
      </a>
      <a href="/calculators/paint-room" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Paint Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Painting your new accent wall? Calculate exactly how many gallons you need.</div>
      </a>
    </div>
  </div>

</Layout>

<script is:inline>
  function toggleSection(id, show) {
    const el = document.getElementById(id);
    if (show) {
      el.classList.remove('hidden');
    } else {
      el.classList.add('hidden');
      // Clear inputs when hiding
      el.querySelectorAll('input').forEach(input => input.value = '');
      calculate();
    }
  }

  function getSqFt(prefix) {
    const hFt = parseFloat(document.getElementById(`${prefix}h_ft`)?.value) || 0;
    const hIn = parseFloat(document.getElementById(`${prefix}h_in`)?.value) || 0;
    const wFt = parseFloat(document.getElementById(`${prefix}w_ft`)?.value) || 0;
    const wIn = parseFloat(document.getElementById(`${prefix}w_in`)?.value) || 0;
    
    const h = hFt + (hIn / 12);
    const w = wFt + (wIn / 12);
    
    return h * w;
  }

  function calculate() {
    let totalSqFt = 0;
    
    // Sum walls
    const w1 = getSqFt('w1');
    const w2 = document.getElementById('wall2Toggle').checked ? getSqFt('w2') : 0;
    const w3 = document.getElementById('wall3Toggle').checked ? getSqFt('w3') : 0;
    
    totalSqFt = w1 + w2 + w3;

    if (totalSqFt <= 0) {
      document.getElementById('errorMsg').classList.remove('hidden');
      document.getElementById('results').classList.add('hidden');
      return;
    }
    document.getElementById('errorMsg').classList.add('hidden');

    // Subtract openings
    let openingSqFt = 0;
    if (document.getElementById('doorToggle').checked) {
      openingSqFt += getSqFt('d');
    }
    if (document.getElementById('windowToggle').checked) {
      openingSqFt += getSqFt('w');
    }

    let netSqFt = totalSqFt - openingSqFt;
    if (netSqFt < 0) netSqFt = 0;

    // Board Profile Logic
    let exposedFaceProfile = document.getElementById('board_profile').value;
    let exposedFaceInches = 0;

    if (exposedFaceProfile === 'custom') {
      document.getElementById('custom_face_div').classList.remove('hidden');
      exposedFaceInches = parseFloat(document.getElementById('custom_face').value) || 5;
    } else {
      document.getElementById('custom_face_div').classList.add('hidden');
      exposedFaceInches = parseFloat(exposedFaceProfile);
    }

    const gapSize = parseFloat(document.getElementById('gap_size').value) || 0;
    const effectiveWidthInches = exposedFaceInches + gapSize;
    const effectiveWidthFeet = effectiveWidthInches / 12;

    const boardLength = parseFloat(document.getElementById('board_length').value) || 8;
    
    // Coverage per board
    const sqFtPerBoard = effectiveWidthFeet * boardLength;

    // Linear Feet required
    const totalLinearFeet = netSqFt / effectiveWidthFeet;
    const linearFeetWithWaste = totalLinearFeet * 1.10; // 10% waste

    // Total Boards required
    const totalBoards = Math.ceil(linearFeetWithWaste / boardLength);

    // Update UI
    document.getElementById('r_sqft').innerText = netSqFt.toFixed(1);
    document.getElementById('r_linear').innerText = Math.ceil(linearFeetWithWaste);
    document.getElementById('r_coverage').innerText = effectiveWidthInches.toFixed(3) + '"';
    document.getElementById('r_boards').innerText = totalBoards;

    // Build dynamic note
    let noteHtml = `<strong>Note:</strong> Calculated for ${netSqFt.toFixed(1)} net square feet (after subtracting ${openingSqFt.toFixed(1)} sqft for openings). `;
    noteHtml += `Using a true coverage face of ${effectiveWidthInches.toFixed(3)} inches (including gap). `;
    noteHtml += `A 10% waste factor was applied to ensure you have enough lumber.`;
    
    document.getElementById('calc_note').innerHTML = noteHtml;

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
  }

  function attachListeners() {
    document.querySelectorAll('input, select').forEach(el => {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate);
    });
    
    // Specific listener to handle custom face visibility immediately
    document.getElementById('board_profile').addEventListener('change', function() {
      if (this.value === 'custom') {
        document.getElementById('custom_face_div').classList.remove('hidden');
      } else {
        document.getElementById('custom_face_div').classList.add('hidden');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', attachListeners);
</script>
