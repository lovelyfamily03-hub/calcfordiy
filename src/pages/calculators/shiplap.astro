---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Shiplap & Tongue and Groove Calculator | CalcForDIY"
  description="Calculate exactly how many shiplap or tongue and groove boards you need for an accent wall. Automatically accounts for exposed face overlap, nickel gaps, and waste."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Shiplap and Tongue and Groove Calculator",
    "description": "Free calculator to estimate shiplap boards needed by calculating the true exposed face width, gap spacing, and exact wall square footage minus doors and windows.",
    "applicationCategory": "CalculatorApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the true exposed face of shiplap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A standard 1x6 shiplap board measures 5.5 inches wide at the store, but the actual exposed face (coverage) is only about 4 7/8 inches (often rounded to 5 inches) because the rabbet edges overlap when installed. If you calculate your wall using the 5.5-inch dimension, you will not buy enough wood."
        }
      },
      {
        "@type": "Question",
        "name": "What size is a nickel gap?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A true nickel gap spacing is 1/8 of an inch. Many modern shiplap boards are milled so the face automatically leaves a 1/8-inch gap when the boards are stacked tight. If you are using raw boards, you can physically use nickels (or 1/8-inch tile spacers) to create this look."
        }
      },
      {
        "@type": "Question",
        "name": "Should I install shiplap horizontally or vertically?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Horizontal shiplap makes a room feel wider and is the traditional farmhouse look. Vertical shiplap draws the eye up, making ceilings feel taller, and leans toward a modern or mid-century aesthetic. Neither affects the square footage needed, but vertical installations may result in slightly more waste if the wall height doesn't divide evenly into the board length."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://calcfordiy.com" },
      { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://calcfordiy.com/calculators" },
      { "@type": "ListItem", "position": 3, "name": "Shiplap Calculator", "item": "https://calcfordiy.com/calculators/shiplap" }
    ]
  }
  </script>

  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4 print:hidden">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <a href="/calculators" class="hover:text-blue-600">Calculators</a>
    <span>/</span>
    <span>Shiplap Calculator</span>
  </div>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Shiplap & T&G Calculator</h1>
    <p class="text-gray-600 text-lg">Calculate exactly how many boards you need for your accent wall. We protect you from under-buying by calculating the true exposed face width minus the overlap!</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    
    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold print:hidden">1</span>
      Board Specs
    </h2>

    <div class="mb-4 p-4 bg-gray-50 rounded-lg">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Board Profile (Nominal)</label>
          <select id="board_profile" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="3">1x4 (Exposed Face: ~3")</option>
            <option value="4.875" selected>1x6 (Exposed Face: ~4 7/8")</option>
            <option value="6.875">1x8 (Exposed Face: ~6 7/8")</option>
            <option value="custom">Custom Exposed Face</option>
          </select>
        </div>
        <div id="custom_face_div" class="hidden">
          <label class="block text-sm font-medium text-gray-700 mb-2">Custom Face (inches)</label>
          <input type="number" id="custom_face" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="5.0" step="0.125" min="1" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Spacing Gap</label>
          <select id="gap_size" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="0" selected>Flush / Built-in Gap (0")</option>
            <option value="0.125">Nickel Gap (1/8")</option>
            <option value="0.25">Quarter Inch (1/4")</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Purchase Board Length</label>
          <select id="board_length" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="8" selected>8 ft boards</option>
            <option value="10">10 ft boards</option>
            <option value="12">12 ft boards</option>
            <option value="16">16 ft boards</option>
          </select>
        </div>
      </div>
      <p class="text-xs text-gray-500 mt-3 italic">Note: If buying pre-milled "nickel gap" shiplap from a big box store, choose "Flush" as the gap is already milled into the face.</p>
    </div>

    <hr class="my-5 border-gray-200 print:hidden" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
