---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Furnace & Heating Cost Calculator — Estimate Winter Bills | CalcForDIY"
  description="Calculate exactly how much it costs to run your gas furnace, electric heater, or heat pump. Compare your monthly heating costs and see if an upgrade is worth it."
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Furnace & Heating Cost Calculator",
    "description": "Free heating cost calculator that estimates hourly, monthly, and seasonal costs for natural gas furnaces, electric heaters, and heat pumps.",
    "applicationCategory": "CalculatorApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a Therm?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Therm is a unit of heat energy equal to 100,000 British Thermal Units (BTU). Natural gas is typically billed by the Therm (or sometimes by CCF, which is roughly equivalent to 1 Therm). If your furnace has an input rating of 100,000 BTU, it consumes exactly 1 Therm of gas for every continuous hour it runs."
        }
      },
      {
        "@type": "Question",
        "name": "Why don't I need my furnace's AFUE rating to calculate my gas cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The AFUE (Annual Fuel Utilization Efficiency) rating tells you what percentage of the gas burned actually turns into usable heat for your home versus going out the exhaust vent. However, a 100,000 BTU input furnace will always burn 100,000 BTUs of gas per hour while running, regardless of whether it is 80% or 95% efficient. The efficiency simply determines how quickly the house warms up (and therefore, how long the furnace stays on), but the hourly burn rate is fixed."
        }
      },
      {
        "@type": "Question",
        "name": "Is a Heat Pump cheaper to run than a Gas Furnace?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends heavily on your local utility rates. Heat pumps are incredibly efficient, often producing 3 units of heat for every 1 unit of electricity they consume. However, electricity is generally much more expensive than natural gas per unit of energy. You can use the 'Compare to Upgrade' toggle in this calculator to run your local electric rate against your local gas rate to see which system is cheaper for your specific home."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://calcfordiy.com" },
      { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://calcfordiy.com/calculators" },
      { "@type": "ListItem", "position": 3, "name": "Furnace & Heating Cost Calculator", "item": "https://calcfordiy.com/calculators/furnace-cost" }
    ]
  }
  </script>

  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4 print:hidden">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <a href="/calculators" class="hover:text-blue-600">Calculators</a>
    <span>/</span>
    <span>Furnace & Heating Cost</span>
  </div>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Furnace & Heating Cost Calculator</h1>
    <p class="text-gray-600 text-lg">Find out exactly what your heating system costs to run per month, and compare gas vs. electric to see if upgrading makes financial sense.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">
    
    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold print:hidden">1</span>
      Your Heating System
    </h2>

    <div class="p-4 bg-gray-50 rounded-lg mb-5">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">System Type</label>
        <select id="sys_type" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
          <option value="gas" selected>Natural Gas Furnace</option>
          <option value="electric">Electric Furnace / Space Heater</option>
          <option value="heatpump">Heat Pump (Air Source)</option>
        </select>
      </div>

      <!-- GAS INPUTS -->
      <div id="gas_inputs" class="grid grid-cols-1 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Input Capacity (BTU/hr)</label>
          <div class="flex items-center gap-2">
            <input type="number" id="gas_btu" placeholder="80000" min="10000" max="250000" step="5000" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">BTU</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Look for "Input BTU" on the furnace nameplate sticker. Common sizes: 40k, 60k, 80k, 100k.</p>
        </div>
      </div>

      <!-- ELECTRIC INPUTS -->
      <div id="electric_inputs" class="hidden grid grid-cols-1 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Heating Capacity (kW)</label>
          <div class="flex items-center gap-2">
            <input type="number" id="elec_kw" placeholder="10" min="0.5" max="50" step="0.5" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">kW</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Standard plug-in space heater = 1.5 kW. Electric baseboard = ~1 kW per 4ft. Central electric furnace = 10kW to 20kW.</p>
        </div>
      </div>

      <!-- HEAT PUMP INPUTS -->
      <div id="heatpump_inputs" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Heating Capacity (BTU/hr)</label>
          <div class="flex items-center gap-2">
            <input type="number" id="hp_btu" placeholder="36000" min="9000" max="60000" step="1000" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">BTU</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Usually 12,000 BTU per "Ton" of size.</p>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">HSPF Rating</label>
          <input type="number" id="hp_hspf" placeholder="8.5" min="6.5" max="15" step="0.1" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <p class="text-xs text-gray-400 mt-1">Found on the EnergyGuide sticker (Average is 8.0 - 9.5).</p>
        </div>
      </div>
    </div>

    <hr class="my-5 border-gray-200 print:hidden" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold print:hidden">2</span>
      Usage and Energy Rates
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Hours Run Per Day</label>
        <div class="flex items-center gap-2">
          <input type="number" id="usage_hrs" placeholder="8" value="8" min="0.5" max="24" step="0.5" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-xs text-gray-500 shrink-0">hrs/day</span>
        </div>
        <p class="text-xs text-gray-400 mt-1">Typically 4-6 hrs in mild winters, 8-12 hrs in freezing climates.</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Heating Season Length</label>
        <div class="flex items-center gap-2">
          <input type="number" id="usage_mos" placeholder="5" value="5" min="1" max="12" step="1" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-xs text-gray-500 shrink-0">months</span>
        </div>
      </div>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-700 mb-2" id="rate_label">Natural Gas Rate ($ per Therm)</label>
      <div class="flex items-center gap-2 max-w-sm">
        <span class="text-sm text-gray-500 shrink-0">$</span>
        <input type="number" id="rate_val" placeholder="1.40" value="1.40" min="0.01" max="10.00" step="0.01" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span class="text-xs text-gray-500 shrink-0" id="rate_unit">per Therm</span>
      </div>
      <p class="text-xs text-blue-800 mt-2 bg-blue-50 p-2 rounded border border-blue-100" id="rate_hint">US average is ~$1.40/Therm. Check your gas bill for your exact rate. If your bill uses CCF, you can still enter the cost per CCF here (1 CCF is almost exactly 1 Therm).</p>
    </div>

    <hr class="my-5 border-gray-200 print:hidden" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold print:hidden">3</span>
      Compare Upgrade (Optional)
    </h2>

    <div class="mb-5">
      <label class="flex items-center gap-2 cursor-pointer p-3 rounded-lg border border-dashed border-gray-300 hover:bg-gray-50">
        <input type="checkbox" id="compareToggle" class="w-4 h-4 rounded text-blue-600" />
        <span class="text-sm text-gray-700">Compare with a new system</span>
      </label>
      <div id="compareSection" class="hidden mt-3 p-4 bg-gray-50 rounded-lg">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-2">New System Type</label>
          <select id="new_sys_type" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-white">
            <option value="heatpump" selected>High-Efficiency Heat Pump</option>
            <option value="gas">New Gas Furnace</option>
          </select>
        </div>

        <!-- NEW GAS INPUTS -->
        <div id="new_gas_inputs" class="hidden grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">New Input (BTU/hr)</label>
            <input type="number" id="new_gas_btu" placeholder="80000" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Gas Rate ($/Therm)</label>
            <input type="number" id="new_gas_rate" placeholder="1.40" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
          </div>
        </div>

        <!-- NEW HEAT PUMP INPUTS -->
        <div id="new_heatpump_inputs" class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="block text-xs text-gray-500 mb-1">New Capacity (BTU)</label>
            <input type="number" id="new_hp_btu" placeholder="36000" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">New HSPF</label>
            <input type="number" id="new_hp_hspf" placeholder="10" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
          </div>
          <div>
            <label class="block text-xs text-gray-500 mb-1">Electric Rate ($/kWh)</label>
            <input type="number" id="new_elec_rate" placeholder="0.16" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" />
          </div>
        </div>
      </div>
    </div>

    <button id="calcBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors text-base print:hidden">
      Calculate Heating Cost →
    </button>
  </div>

  <div id="errorMsg" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-red-700 text-sm print:hidden">
    Please ensure all required fields for your system type are filled out correctly.
  </div>

  <div id="results" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 mb-8 print:bg-white print:border-gray-300 print:from-white print:to-white print:shadow-none">
    <h2 class="text-lg font-semibold text-blue-900 mb-4 print:text-xl print:text-gray-900">Your Heating Cost Estimate</h2>
    
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
      <div class="bg-white rounded-lg p-4 text-center shadow-sm print:border print:border-gray-200 print:shadow-none">
        <div class="text-2xl font-bold text-gray-900 print:text-3xl" id="r_hour">—</div>
        <div class="text-xs text-gray-500 mt-1">Cost Per Hour (While running)</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm print:border print:border-gray-200 print:shadow-none">
        <div class="text-2xl font-bold text-gray-900 print:text-3xl" id="r_month">—</div>
        <div class="text-xs text-gray-500 mt-1">Average Monthly Cost</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm border-2 border-blue-400 print:border-gray-400 print:shadow-none">
        <div class="text-2xl font-bold text-blue-700 print:text-3xl print:text-gray-900" id="r_season">—</div>
        <div class="text-xs text-gray-700 font-medium mt-1">Total Seasonal Cost</div>
      </div>
    </div>

    <div id="savings_box" class="hidden mt-4 pt-4 border-t border-blue-200 print:border-gray-300">
      <h3 class="text-sm font-semibold text-blue-900 mb-3 print:text-gray-900">Upgrade Comparison</h3>
      <div class="flex flex-col sm:flex-row gap-4">
        <div class="flex-1 bg-white p-3 rounded-lg border border-blue-100 shadow-sm print:border-gray-200 print:shadow-none">
          <div class="text-xs text-gray-500 mb-1">New System Seasonal Cost</div>
          <div class="text-lg font-bold text-gray-900" id="r_new_season">—</div>
        </div>
        <div class="flex-1 bg-green-50 p-3 rounded-lg border border-green-200 shadow-sm print:border-gray-200 print:shadow-none">
          <div class="text-xs text-green-800 mb-1 font-medium">Estimated Annual Savings</div>
          <div class="text-xl font-bold text-green-700" id="r_savings">—</div>
        </div>
      </div>
    </div>
    
    <button onclick="window.print()" class="hidden mt-5 w-full bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 px-6 rounded-lg transition-colors print:hidden text-base justify-center items-center gap-2" id="printBtn">
      🖨️ Print Estimate
    </button>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6 print:hidden">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">How to Use This Calculator</h2>
    <p class="text-gray-700 mb-4">Estimate your winter heating bills by following these steps:</p>
    <ol class="space-y-4 text-gray-700">
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
        <span><strong>Select Your Heating System:</strong> Choose between a natural gas furnace, electric resistance heat (like baseboards or space heaters), or an air-source heat pump.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
        <span><strong>Find Your Capacity:</strong> Check the sticker on your heating unit. For gas, enter the 'Input BTU'. For electric, enter the 'kW'. For heat pumps, enter the 'BTU' and the 'HSPF' efficiency rating from the EnergyGuide label.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
        <span><strong>Enter Your Utility Rates:</strong> Look at your latest utility bill. Enter your exact cost per Therm (for gas) or cost per kWh (for electric and heat pumps).</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">4</span>
        <span><strong>Compare (Optional):</strong> If you are thinking about replacing your old gas furnace with a high-efficiency heat pump, click the 'Compare' toggle to run the math and see your potential annual savings based on your local rates.</span>
      </li>
    </ol>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6 print:hidden">
    <h2 class="text-xl font-semibold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-5">
      <div>
        <h3 class="font-bold text-gray-900 mb-1">What is a Therm?</h3>
        <p class="text-gray-600 text-sm">A Therm is a unit of heat energy equal to 100,000 British Thermal Units (BTU). Natural gas is typically billed by the Therm (or sometimes by CCF, which is roughly equivalent to 1 Therm). If your furnace has an input rating of 100,000 BTU, it consumes exactly 1 Therm of gas for every continuous hour it runs.</p>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Why don't I need my furnace's AFUE rating to calculate my gas cost?</h3>
        <p class="text-gray-600 text-sm">The AFUE (Annual Fuel Utilization Efficiency) rating tells you what percentage of the gas burned actually turns into usable heat for your home versus going out the exhaust vent. However, a 100,000 BTU input furnace will always burn 100,000 BTUs of gas per hour while running, regardless of whether it is 80% or 95% efficient. The efficiency simply determines how quickly the house warms up (and therefore, how long the furnace stays on), but the hourly fuel burn rate is fixed.</p>
      </div>
      <div>
        <h3 class="font-bold text-gray-900 mb-1">Is a Heat Pump cheaper to run than a Gas Furnace?</h3>
        <p class="text-gray-600 text-sm">It depends heavily on your local utility rates. Heat pumps are incredibly efficient, often producing 3 units of heat for every 1 unit of electricity they consume. However, electricity is generally much more expensive than natural gas per unit of energy. You can use the 'Compare to Upgrade' toggle in this calculator to run your local electric rate against your local gas rate to see which system is cheaper for your specific home.</p>
      </div>
    </div>
  </div>

  <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 print:hidden">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Calculators</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <a href="/calculators/ac-cost" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">AC Operating Cost Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Flip the switch to summer and calculate your central air conditioning costs.</div>
      </a>
      <a href="/calculators/drywall" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Drywall Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Calculate sheetrock counts if you are framing and insulating new walls to keep the heat in.</div>
      </a>
      <a href="/calculators/water-heater-cost" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Water Heater Cost Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Estimate the annual cost of running your gas or electric water heater.</div>
      </a>
    </div>
  </div>

</Layout>

<script is:inline>
  
  // UI Toggles
  function updateSystemUI() {
    const sys = document.getElementById('sys_type').value;
    const rl = document.getElementById('rate_label');
    const ru = document.getElementById('rate_unit');
    const rh = document.getElementById('rate_hint');
    const rv = document.getElementById('rate_val');

    document.getElementById('gas_inputs').classList.add('hidden');
    document.getElementById('electric_inputs').classList.add('hidden');
    document.getElementById('heatpump_inputs').classList.add('hidden');

    if (sys === 'gas') {
      document.getElementById('gas_inputs').classList.remove('hidden');
      rl.innerText = 'Natural Gas Rate ($ per Therm)';
      ru.innerText = 'per Therm';
      rh.innerText = 'US average is ~$1.40/Therm. Check your gas bill for your exact rate. If your bill uses CCF, you can still enter the cost per CCF here (1 CCF is almost exactly 1 Therm).';
      if(!rv.dataset.userEdited) rv.value = '1.40';
    } else if (sys === 'electric') {
      document.getElementById('electric_inputs').classList.remove('hidden');
      rl.innerText = 'Electric Rate ($ per kWh)';
      ru.innerText = 'per kWh';
      rh.innerText = 'US average is ~$0.16/kWh. Check your electric bill for your exact rate.';
      if(!rv.dataset.userEdited) rv.value = '0.16';
    } else if (sys === 'heatpump') {
      document.getElementById('heatpump_inputs').classList.remove('hidden');
      rl.innerText = 'Electric Rate ($ per kWh)';
      ru.innerText = 'per kWh';
      rh.innerText = 'US average is ~$0.16/kWh. Check your electric bill for your exact rate.';
      if(!rv.dataset.userEdited) rv.value = '0.16';
    }
    
    // Clear results on change
    document.getElementById('results').classList.add('hidden');
  }

  function updateCompareUI() {
    const compareOn = document.getElementById('compareToggle').checked;
    const cSec = document.getElementById('compareSection');
    
    if (compareOn) {
      cSec.classList.remove('hidden');
      const newSys = document.getElementById('new_sys_type').value;
      if (newSys === 'gas') {
        document.getElementById('new_gas_inputs').classList.remove('hidden');
        document.getElementById('new_heatpump_inputs').classList.add('hidden');
      } else {
        document.getElementById('new_heatpump_inputs').classList.remove('hidden');
        document.getElementById('new_gas_inputs').classList.add('hidden');
      }
    } else {
      cSec.classList.add('hidden');
    }
  }

  // Math Functions
  function calcHourlyCost(sysType, btu, kw, hspf, rate) {
    if (sysType === 'gas') {
      // 1 Therm = 100,000 BTU
      return (btu / 100000) * rate;
    } else if (sysType === 'electric') {
      return kw * rate;
    } else if (sysType === 'heatpump') {
      // (BTU / HSPF) = Watt-hours. Div 1000 for kWh.
      const kwh = (btu / hspf) / 1000;
      return kwh * rate;
    }
    return 0;
  }

  function calculate() {
    const sys = document.getElementById('sys_type').value;
    const rate = parseFloat(document.getElementById('rate_val').value);
    const hrs = parseFloat(document.getElementById('usage_hrs').value);
    const mos = parseFloat(document.getElementById('usage_mos').value);
    
    let isValid = false;
    let btu = 0;
    let kw = 0;
    let hspf = 0;

    if (sys === 'gas') {
      btu = parseFloat(document.getElementById('gas_btu').value);
      if (btu > 0 && rate > 0) isValid = true;
    } else if (sys === 'electric') {
      kw = parseFloat(document.getElementById('elec_kw').value);
      if (kw > 0 && rate > 0) isValid = true;
    } else if (sys === 'heatpump') {
      btu = parseFloat(document.getElementById('hp_btu').value);
      hspf = parseFloat(document.getElementById('hp_hspf').value);
      if (btu > 0 && hspf > 0 && rate > 0) isValid = true;
    }

    if (!isValid || hrs <= 0 || mos <= 0) {
      document.getElementById('errorMsg').classList.remove('hidden');
      document.getElementById('results').classList.add('hidden');
      return;
    }
    document.getElementById('errorMsg').classList.add('hidden');

    const hourlyCost = calcHourlyCost(sys, btu, kw, hspf, rate);
    const monthlyCost = hourlyCost * hrs * 30; // approx 30 days per month
    const seasonalCost = monthlyCost * mos;

    // Display Main Results
    const f = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' });
    document.getElementById('r_hour').innerText = f.format(hourlyCost);
    document.getElementById('r_month').innerText = f.format(monthlyCost);
    document.getElementById('r_season').innerText = f.format(seasonalCost);

    // Handle Compare Logic
    const compareOn = document.getElementById('compareToggle').checked;
    const sb = document.getElementById('savings_box');
    
    if (compareOn) {
      const newSys = document.getElementById('new_sys_type').value;
      let newHourly = 0;
      
      if (newSys === 'gas') {
        const nBtu = parseFloat(document.getElementById('new_gas_btu').value) || 0;
        const nRate = parseFloat(document.getElementById('new_gas_rate').value) || 0;
        newHourly = calcHourlyCost('gas', nBtu, 0, 0, nRate);
      } else {
        const nBtu = parseFloat(document.getElementById('new_hp_btu').value) || 0;
        const nHspf = parseFloat(document.getElementById('new_hp_hspf').value) || 0;
        const nRate = parseFloat(document.getElementById('new_elec_rate').value) || 0;
        newHourly = calcHourlyCost('heatpump', nBtu, 0, nHspf, nRate);
      }
      
      if (newHourly > 0) {
        const newSeasonal = newHourly * hrs * 30 * mos;
        const savings = seasonalCost - newSeasonal;
        
        document.getElementById('r_new_season').innerText = f.format(newSeasonal);
        
        const rSav = document.getElementById('r_savings');
        if (savings > 0) {
          rSav.innerText = f.format(savings);
          rSav.classList.remove('text-red-600', 'text-gray-600');
          rSav.classList.add('text-green-700');
        } else if (savings < 0) {
          rSav.innerText = "-" + f.format(Math.abs(savings)) + " (Costs more)";
          rSav.classList.remove('text-green-700', 'text-gray-600');
          rSav.classList.add('text-red-600');
        } else {
          rSav.innerText = "$0.00";
          rSav.classList.remove('text-green-700', 'text-red-600');
          rSav.classList.add('text-gray-600');
        }
        sb.classList.remove('hidden');
      } else {
        sb.classList.add('hidden');
      }
    } else {
      sb.classList.add('hidden');
    }

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    document.getElementById('printBtn').classList.add('flex');
  }

  // Initialization
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('sys_type').addEventListener('change', updateSystemUI);
    
    document.getElementById('compareToggle').addEventListener('change', updateCompareUI);
    document.getElementById('new_sys_type').addEventListener('change', updateCompareUI);
    
    document.getElementById('rate_val').addEventListener('input', function() {
      this.dataset.userEdited = 'true';
    });
    
    document.getElementById('calcBtn').addEventListener('click', calculate);
  });
</script>
