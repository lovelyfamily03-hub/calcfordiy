---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Recessed Lighting Calculator for Garage — How Many Lights? | CalcForDIY"
  description="Calculate how many recessed lights you need for your garage. Enter dimensions, ceiling height, and fixture lumens to get an instant fixture count and spacing guide. Free, no signup."
>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Recessed Lighting Calculator for Garage",
    "description": "Free calculator that estimates how many recessed lights you need for a garage based on room size, ceiling height, and target brightness.",
    "applicationCategory": "CalculatorApplication",
    "operatingSystem": "Web Browser",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between lumens and foot-candles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lumens measure the total light a fixture produces, while foot-candles measure how much of that light actually hits a surface. When using a recessed lighting calculator for garage spaces, foot-candles are the planning target, and lumens are the variable you adjust to meet it."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use 4-inch or 6-inch recessed fixtures in a garage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For a garage, 6-inch fixtures are highly recommended. They provide a wider beam spread and higher lumen outputs, which are essential for properly illuminating spaces with high ceilings and large footprints. 4-inch fixtures are better suited for interior living spaces."
      }
    },
    {
      "@type": "Question",
      "name": "How many lights do I need for a 2-car versus a 3-car garage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "As a quick reference, a standard 2-car garage typically requires 6 to 8 recessed fixtures (at 750 lumens each) for general parking. A larger 3-car garage will generally require 10 to 12 fixtures to achieve the same brightness."
      }
    },
    {
      "@type": "Question",
      "name": "Are LED shop lights better than recessed cans for garages?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on your ceiling. Surface-mounted LED shop lights are excellent for unfinished ceilings and provide massive lumen output. Recessed cans require a finished drywall ceiling but offer a clean, flush look that won't interfere with tall vehicles or ladders."
      }
    },
    {
      "@type": "Question",
      "name": "How do I position the first row of fixtures?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The first row of fixtures should be placed at exactly half the distance of your regular fixture spacing. For example, if your lights are spaced 8 feet apart, the first row should be positioned 4 feet away from the wall."
      }
    },
    {
      "@type": "Question",
      "name": "Do garage door openers affect light placement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You must account for the garage door tracks, the opener motor, and the open door itself. A raised garage door will block fixtures placed directly above it, so position your lights between the tracks to ensure the floor remains illuminated when the door is open."
      }
    }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://calcfordiy.com" },
      { "@type": "ListItem", "position": 2, "name": "Recessed Lighting Calculator — Garage", "item": "https://calcfordiy.com/calculators/recessed-lights-garage" }
    ]
  }
  </script>

  <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
    <a href="/" class="hover:text-blue-600">Home</a>
    <span>/</span>
    <span>Recessed Lighting Calculator — Garage</span>
  </div>

  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-3">Recessed Lighting Calculator — Garage</h1>
    <p class="text-gray-600 text-lg">Enter your garage dimensions and how you use the space to get an accurate fixture count and spacing recommendation based on IES lighting standards.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-6 mb-6">

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold">1</span>
      Garage Dimensions
    </h2>

    <div class="p-4 bg-gray-50 rounded-lg mb-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs text-gray-500 mb-1">Garage Length</label>
          <div class="flex items-center gap-2">
            <input type="number" id="g_len_ft" placeholder="24" min="0" max="200"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">ft</span>
            <input type="number" id="g_len_in" placeholder="0" min="0" max="11"
              class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">in</span>
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Garage Width</label>
          <div class="flex items-center gap-2">
            <input type="number" id="g_wid_ft" placeholder="20" min="0" max="200"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">ft</span>
            <input type="number" id="g_wid_in" placeholder="0" min="0" max="11"
              class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-xs text-gray-500 shrink-0">in</span>
          </div>
        </div>
      </div>

      <div>
        <label class="block text-xs text-gray-500 mb-1">Ceiling Height</label>
        <div class="flex items-center gap-2">
          <input type="number" id="g_ceil_ft" placeholder="9" min="6" max="20"
            class="w-32 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-xs text-gray-500 shrink-0">ft</span>
          <input type="number" id="g_ceil_in" placeholder="0" min="0" max="11"
            class="w-16 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-xs text-gray-500 shrink-0">in</span>
        </div>
      </div>
    </div>

    <hr class="my-5 border-gray-200" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold">2</span>
      Lighting Settings
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Primary Use</label>
        <select id="purpose"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="50">General parking / storage (50 foot-candles)</option>
          <option value="100">Workshop / detailed work (100 foot-candles)</option>
        </select>
        <p class="text-xs text-gray-400 mt-1">IES recommended levels for residential garages</p>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Fixture Lumens</label>
        <select id="lumens"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="650">650 lm — 6" LED, basic</option>
          <option value="750" selected>750 lm — 6" LED, standard</option>
          <option value="1000">1000 lm — 6" LED, bright</option>
          <option value="1500">1500 lm — 8" LED, high output</option>
          <option value="2000">2000 lm — Shop light / high bay</option>
        </select>
        <p class="text-xs text-gray-400 mt-1">Check your fixture packaging for exact lumens</p>
      </div>
    </div>

    <button onclick="calculate()"
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors text-base">
      Calculate Fixtures Needed →
    </button>

  </div>

  <div id="errorMsg" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-red-700 text-sm">
    Please enter your garage length and width to calculate.
  </div>

  <div id="results" class="hidden bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-xl p-6 mb-8">
    <h2 class="text-lg font-semibold text-blue-900 mb-4">Your Lighting Estimate</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-gray-900" id="r_area">—</div>
        <div class="text-xs text-gray-500 mt-1">Floor Area</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-blue-700" id="r_target">—</div>
        <div class="text-xs text-gray-500 mt-1">Target Foot-Candles</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-green-700" id="r_fixtures">—</div>
        <div class="text-xs text-gray-500 mt-1">Fixtures Needed</div>
      </div>
      <div class="bg-white rounded-lg p-4 text-center shadow-sm">
        <div class="text-2xl font-bold text-gray-900" id="r_spacing">—</div>
        <div class="text-xs text-gray-500 mt-1">Suggested Spacing</div>
      </div>
    </div>
    <div class="bg-white rounded-lg p-4 shadow-sm mb-3">
      <p class="text-sm font-medium text-gray-700 mb-1">Layout Suggestion</p>
      <p class="text-sm text-gray-600" id="r_layout">—</p>
    </div>
    <p class="text-xs text-blue-800 bg-blue-200 bg-opacity-50 rounded-lg p-3">
      <strong>Tip:</strong> Position the first row of fixtures half the spacing distance from the wall. For example if spacing is 6 ft, first fixture row is 3 ft from each wall.
    </p>
    <button id="printBtn" onclick="window.print()" class="hidden mt-5 w-full bg-gray-800 hover:bg-gray-900 text-white font-semibold py-3 px-6 rounded-lg transition-colors print:hidden text-base flex justify-center items-center gap-2">

      🖨️ Print or Save as PDF

    </button>

  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">How to Use This Calculator</h2>
    <p class="text-gray-700 mb-4">Using this recessed lighting calculator for garage planning is straightforward. Follow these steps to get an accurate fixture count and layout:</p>
    <ol class="space-y-4 text-gray-700">
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">1</span>
        <span><strong>Enter garage dimensions.</strong> Measure the length and width of your garage in feet and inches.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">2</span>
        <span><strong>Enter ceiling height.</strong> Input the height of your garage ceiling, which directly affects the required fixture spacing.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">3</span>
        <span><strong>Select primary use.</strong> Choose whether the space is for general parking or detailed workshop tasks. Foot-candles are the industry standard unit for measuring how much light reaches a surface. The Illuminating Engineering Society (IES) sets recommended levels for residential garages at 50 foot-candles for general use and 100 foot-candles for workshops.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">4</span>
        <span><strong>Choose fixture lumens.</strong> Select the lumen output of the specific recessed lights you plan to buy.</span>
      </li>
      <li class="flex gap-3">
        <span class="bg-blue-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-sm font-bold shrink-0 mt-0.5">5</span>
        <span><strong>Review your estimate.</strong> Check the results for your total fixture count, suggested spacing, and grid layout recommendation.</span>
      </li>
    </ol>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-4">The Formula</h2>
    <p class="text-gray-700 mb-4">This recessed lighting calculator for garage layouts relies on standard lighting formulas to determine your needs. Here is the math:</p>
    <div class="bg-gray-50 rounded-lg p-4 mb-5 font-mono text-sm text-gray-800 space-y-1">
      <p>Fixtures Needed = (Floor Area × Target Foot-Candles) / (Lumens per Fixture × 0.75)</p>
    </div>
    <p class="text-gray-700">The number of fixtures needed equals your floor area multiplied by your target foot-candles, divided by the fixture's lumen output multiplied by 0.75. The 0.75 represents the coefficient of utilization, which accounts for the light absorbed by the walls and ceiling before reaching the floor. All values are based on IES residential lighting guidelines.</p>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="text-xl font-semibold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-5">
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">What is the difference between lumens and foot-candles?</h3>
        <p class="text-gray-600 text-sm">Lumens measure the total light a fixture produces, while foot-candles measure how much of that light actually hits a surface. When using a recessed lighting calculator for garage spaces, foot-candles are the planning target, and lumens are the variable you adjust to meet it.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Should I use 4-inch or 6-inch recessed fixtures in a garage?</h3>
        <p class="text-gray-600 text-sm">For a garage, 6-inch fixtures are highly recommended. They provide a wider beam spread and higher lumen outputs, which are essential for properly illuminating spaces with high ceilings and large footprints. 4-inch fixtures are better suited for interior living spaces.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">How many lights do I need for a 2-car versus a 3-car garage?</h3>
        <p class="text-gray-600 text-sm">As a quick reference, a standard 2-car garage typically requires 6 to 8 recessed fixtures (at 750 lumens each) for general parking. A larger 3-car garage will generally require 10 to 12 fixtures to achieve the same brightness.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Are LED shop lights better than recessed cans for garages?</h3>
        <p class="text-gray-600 text-sm">It depends on your ceiling. Surface-mounted LED shop lights are excellent for unfinished ceilings and provide massive lumen output. Recessed cans require a finished drywall ceiling but offer a clean, flush look that won't interfere with tall vehicles or ladders.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">How do I position the first row of fixtures?</h3>
        <p class="text-gray-600 text-sm">The first row of fixtures should be placed at exactly half the distance of your regular fixture spacing. For example, if your lights are spaced 8 feet apart, the first row should be positioned 4 feet away from the wall.</p>
      </div>
      <div>
        <h3 class="font-semibold text-gray-900 mb-1">Do garage door openers affect light placement?</h3>
        <p class="text-gray-600 text-sm">Yes. You must account for the garage door tracks, the opener motor, and the open door itself. A raised garage door will block fixtures placed directly above it, so position your lights between the tracks to ensure the floor remains illuminated when the door is open.</p>
      </div>
    </div>
  </div>

  <div class="bg-gray-50 border border-gray-200 rounded-xl p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Related Calculators</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <a href="/calculators/recessed-lights-bedroom" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Recessed Lighting Calculator — Bedroom</div>
        <div class="text-xs text-gray-500 mt-1">Calculate the perfect number of can lights for a bedroom.</div>
      </a>
      <a href="/calculators/lumens" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Lumens Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Find out exactly how many lumens you need for any room.</div>
      </a>
      <a href="/calculators/bathroom-wall-tile" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Bathroom Wall Tile Calculator</div>
        <div class="text-xs text-gray-500 mt-1">Estimate tile needed for bathroom walls with waste included.</div>
      </a>
    </div>
  </div>

</Layout>

<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function toFt(ftId, inId) {
    return getNum(ftId) + getNum(inId) / 12;
  }

  function calculate() {
    var len = toFt('g_len_ft', 'g_len_in');
    var wid = toFt('g_wid_ft', 'g_wid_in');
    var ceilHeight = toFt('g_ceil_ft', 'g_ceil_in');

    document.getElementById('errorMsg').classList.add('hidden');

    if (len <= 0 || wid <= 0) {
      document.getElementById('results').classList.add('hidden');
      if (len > 0 || wid > 0) document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    var area = len * wid;
    var targetFC = parseInt(document.getElementById('purpose').value) || 50;
    var lumensPerFixture = parseInt(document.getElementById('lumens').value) || 750;

    // IES formula: fixtures = (area x FC) / (lumens x CU)
    // CU (coefficient of utilization) = 0.75 for typical garage with light walls/ceiling
    var cu = 0.75;
    var fixturesNeeded = Math.ceil((area * targetFC) / (lumensPerFixture * cu));

    // Suggest spacing based on ceiling height
    // Rule of thumb: spacing = ceiling height x 0.75 (IES guideline)
    var suggestedSpacing = ceilHeight > 0 ? ceilHeight * 0.75 : Math.sqrt(area / fixturesNeeded);
    suggestedSpacing = Math.round(suggestedSpacing * 10) / 10;

    // Calculate grid layout suggestion
    var cols = Math.round(Math.sqrt(fixturesNeeded * (len / wid)));
    var rows = Math.ceil(fixturesNeeded / cols);
    cols = Math.ceil(fixturesNeeded / rows);

    var layoutText = rows + ' row' + (rows > 1 ? 's' : '') + ' × ' + cols + ' fixture' + (cols > 1 ? 's' : '') + ' per row (' + (rows * cols) + ' total). Space fixtures ' + suggestedSpacing + ' ft apart.';

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    document.getElementById('r_area').textContent = area.toFixed(0) + ' sq ft';
    document.getElementById('r_target').textContent = targetFC + ' FC';
    document.getElementById('r_fixtures').textContent = fixturesNeeded + ' fixtures';
    document.getElementById('r_spacing').textContent = suggestedSpacing + ' ft';
    document.getElementById('r_layout').textContent = layoutText;

    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('purpose').addEventListener('change', calculate);
    document.getElementById('lumens').addEventListener('change', calculate);
  });
</script>
