        <div class="text-xs text-gray-500 mt-1">Determine exactly how bright a room needs to be based on its size and purpose.</div>
      </a>
      <a href="/calculators/recessed-lights-garage" class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-sm transition-all">
        <div class="font-medium text-gray-900 text-sm">Recessed Lighting for Garage</div>
        <div class="text-xs text-gray-500 mt-1">Plan the perfect recessed lighting grid layout for an active garage workspace.</div>
      </a>
    </div>
  </div>

</Layout>

<script is:inline>
  function getNum(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function isChecked(id) {
    return document.getElementById(id).checked;
  }

  function toggleSection(sectionId, show) {
    document.getElementById(sectionId).classList.toggle('hidden', !show);
    calculate();
  }

  function applyHouseholdSize() {
    var val = document.getElementById('household_size').value;
    if (val) {
      document.getElementById('daily_gallons').value = val;
      calculate();
    }
  }

  function updateFuelLabels() {
    var fuel = document.getElementById('fuel_type').value;
    var rateLabel = document.getElementById('rate_label');
    var rateUnit = document.getElementById('rate_unit');
    var rateHint = document.getElementById('rate_hint');
    var effHint = document.getElementById('efficiency_hint');

    if (fuel === 'gas') {
      rateLabel.textContent = 'Natural Gas Rate';
      rateUnit.textContent = 'per therm';
      rateHint.textContent = 'US average: ~$1.20 per therm. Check your gas bill.';
      effHint.textContent = 'Typical tank: 0.58-0.70 UEF. High efficiency: 0.80+';
      document.getElementById('utility_rate').placeholder = '1.20';
    } else if (fuel === 'electric') {
      rateLabel.textContent = 'Electric Rate';
      rateUnit.textContent = 'per kWh';
      rateHint.textContent = 'US average: ~$0.16 per kWh. Check your electric bill.';
      effHint.textContent = 'Standard electric tank: 0.90-0.95 UEF';
      document.getElementById('utility_rate').placeholder = '0.16';
    } else if (fuel === 'propane') {
      rateLabel.textContent = 'Propane Rate';
      rateUnit.textContent = 'per gallon';
      rateHint.textContent = 'US average: ~$2.50 per gallon. Varies significantly by region.';
      effHint.textContent = 'Propane tank: 0.58-0.70 UEF. Tankless: 0.82-0.96';
      document.getElementById('utility_rate').placeholder = '2.50';
    } else if (fuel === 'heatpump') {
      rateLabel.textContent = 'Electric Rate';
      rateUnit.textContent = 'per kWh';
      rateHint.textContent = 'US average: ~$0.16 per kWh. Check your electric bill.';
      effHint.textContent = 'Heat pump water heaters: 2.0-4.0 UEF (very high efficiency)';
      document.getElementById('utility_rate').placeholder = '0.16';
    }

    calculate();
  }

  function calcAnnualCost(gallons, inletTemp, targetTemp, efficiency, fuel, rate) {
    // BTUs per day = gallons × 8.34 lbs/gal × temperature rise × 1 BTU/lb°F
    var tempRise = targetTemp - inletTemp;
    if (tempRise <= 0) return null;
    var btuPerDay = gallons * 8.34 * tempRise;

    // Energy per day
    var energyPerDay, costPerDay;

    if (fuel === 'gas') {
      // 1 therm = 100,000 BTU
      energyPerDay = (btuPerDay / 100000) / efficiency;
      costPerDay = energyPerDay * rate;
    } else if (fuel === 'electric' || fuel === 'heatpump') {
      // 1 kWh = 3,412 BTU
      energyPerDay = (btuPerDay / 3412) / efficiency;
      costPerDay = energyPerDay * rate;
    } else if (fuel === 'propane') {
      // 1 gallon propane = 91,500 BTU
      energyPerDay = (btuPerDay / 91500) / efficiency;
      costPerDay = energyPerDay * rate;
    }

    return {
      btuPerDay: btuPerDay,
      energyPerDay: energyPerDay,
      costPerDay: costPerDay,
      monthly: costPerDay * 30.4,
      annual: costPerDay * 365
    };
  }

  function calculate() {
    var gallons = getNum('daily_gallons');
    var inletTemp = getNum('inlet_temp');
    var targetTemp = getNum('target_temp');
    var efficiency = getNum('efficiency');
    var rate = getNum('utility_rate');
    var fuel = document.getElementById('fuel_type').value;

    document.getElementById('errorMsg').classList.add('hidden');

    if (gallons <= 0 || inletTemp <= 0 || targetTemp <= 0 || efficiency <= 0 || rate <= 0) {
      document.getElementById('results').classList.add('hidden');
      document.getElementById('printBtn').classList.add('hidden');
      if (gallons > 0 || inletTemp > 0) document.getElementById('errorMsg').classList.remove('hidden');
      return;
    }

    if (targetTemp <= inletTemp) {
      document.getElementById('errorMsg').classList.remove('hidden');
      document.getElementById('errorMsg').textContent = 'Target temperature must be higher than inlet temperature.';
      document.getElementById('results').classList.add('hidden');
      document.getElementById('printBtn').classList.add('hidden');
      return;
    }

    var result = calcAnnualCost(gallons, inletTemp, targetTemp, efficiency, fuel, rate);
    if (!result) return;

    // Format energy unit label
    var energyLabel = 'therms/day';
    if (fuel === 'electric' || fuel === 'heatpump') energyLabel = 'kWh/day';
    if (fuel === 'propane') energyLabel = 'gal propane/day';

    var breakdown = 'Your water heater heats ' + gallons + ' gallons per day by ' +
      (targetTemp - inletTemp).toFixed(0) + '°F (' + inletTemp + '°F → ' + targetTemp + '°F), ' +
      'requiring ' + result.btuPerDay.toLocaleString(undefined, {maximumFractionDigits: 0}) + ' BTUs/day. ' +
      'At ' + (efficiency * 100).toFixed(0) + '% efficiency that is ' +
      result.energyPerDay.toFixed(3) + ' ' + energyLabel + ' at $' + rate + ' = $' +
      result.costPerDay.toFixed(2) + '/day.';

    document.getElementById('results').classList.remove('hidden');
    document.getElementById('printBtn').classList.remove('hidden');
    
    document.getElementById('r_btu').textContent = result.btuPerDay.toLocaleString(undefined, {maximumFractionDigits: 0});
    document.getElementById('r_daily_energy').textContent = result.energyPerDay.toFixed(3);
    document.getElementById('r_daily_energy_label').textContent = energyLabel;
    document.getElementById('r_monthly').textContent = '$' + result.monthly.toFixed(2);
    document.getElementById('r_annual').textContent = '$' + result.annual.toFixed(2) + '/yr';
    document.getElementById('r_breakdown').textContent = breakdown;

    // Comparison results
    var compResults = document.getElementById('comparisonResults');
    if (isChecked('compareToggle')) {
      var newEfficiency = getNum('new_efficiency');
      var newFuel = document.getElementById('new_fuel_type').value;
      var installCost = getNum('install_cost');

      // Use same rate for same fuel, otherwise need separate rate input
      // For simplicity use same rate if same fuel type
      var newRate = rate;

      if (newEfficiency > 0) {
        var newResult = calcAnnualCost(gallons, inletTemp, targetTemp, newEfficiency, newFuel, newRate);
        if (newResult) {
          var annualSavings = result.annual - newResult.annual;
          var paybackText = '—';
          if (installCost > 0 && annualSavings > 0) {
            var paybackYears = installCost / annualSavings;
            paybackText = paybackYears.toFixed(1) + ' years';
          } else if (annualSavings <= 0) {
            paybackText = 'No savings — current unit is more efficient';
          }

          compResults.classList.remove('hidden');
          document.getElementById('r_new_annual').textContent = '$' + newResult.annual.toFixed(2) + '/yr';
          document.getElementById('r_annual_savings').textContent = annualSavings > 0
            ? '$' + annualSavings.toFixed(2) + '/yr saved'
            : '$' + Math.abs(annualSavings).toFixed(2) + '/yr more';
          document.getElementById('r_payback').textContent = paybackText;
        }
      } else {
        compResults.classList.add('hidden');
      }
    } else {
      compResults.classList.add('hidden');
    }
    
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('input[type="number"]').forEach(function (el) {
      el.addEventListener('input', calculate);
    });
    document.getElementById('fuel_type').addEventListener('change', updateFuelLabels);
    document.getElementById('new_fuel_type') && document.getElementById('new_fuel_type').addEventListener('change', calculate);
    document.getElementById('inlet_temp').value = '55';
    document.getElementById('target_temp').value = '120';
    document.getElementById('efficiency').value = '0.67';
    document.getElementById('utility_rate').value = '1.20';
  });
</script>