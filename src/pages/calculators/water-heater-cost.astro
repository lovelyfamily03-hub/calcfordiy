          </div>
          <p class="text-xs text-gray-400 mt-1">DOE uses 64 gallons/day for a family of four</p>
        </div>
        <div>
          <label class="block text-xs text-gray-500 mb-1">Cold Water Inlet Temperature</label>
          <div class="flex items-center gap-2">
            <input type="number" id="inlet_temp" placeholder="55" min="35" max="80"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
            <span class="text-sm text-gray-500 shrink-0">°F</span>
          </div>
          <p class="text-xs text-gray-400 mt-1">Typical: 45°F cold climates, 55°F moderate, 70°F warm</p>
        </div>
      </div>

      <div class="mt-4">
        <label class="block text-xs text-gray-500 mb-1">Target Water Temperature</label>
        <div class="flex items-center gap-3">
          <input type="number" id="target_temp" placeholder="120" min="100" max="160"
            class="w-32 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <span class="text-sm text-gray-500">°F</span>
          <span class="text-xs text-gray-400">DOE recommends 120°F to prevent scalding and reduce cost</span>
        </div>
      </div>
    </div>

    <hr class="my-5 border-gray-200" />

    <h2 class="text-base font-semibold text-gray-800 mb-4 flex items-center gap-2">
      <span class="bg-blue-100 text-blue-700 rounded-full w-6 h-6 flex items-center justify-center text-xs font-bold">2</span>
      Current Water Heater
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Fuel Type</label>
        <select id="fuel_type"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          onchange="updateFuelLabels()">
          <option value="gas">Natural Gas</option>
          <option value="electric">Electric</option>
          <option value="propane">Propane</option>
          <option value="heatpump">Heat Pump Water Heater</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
