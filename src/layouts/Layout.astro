---
import '../styles/global.css';
const { title, description, noindex = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <title>{title}</title>
  <link rel="canonical" href={`https://calcfordiy.com${Astro.url.pathname}`} />
  
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-SK11L47SS5" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-SK11L47SS5');
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6410565511961171" crossorigin="anonymous" is:inline></script>
</head>
  <body class="bg-gray-50 text-gray-900 overflow-x-hidden">
    <header class="bg-white border-b border-gray-200 px-4 py-3">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-blue-600">CalcForDIY</a>
         <nav class="text-sm text-gray-600 flex gap-5 font-medium">
          <a href="/calculators" class="hover:text-blue-600 transition-colors">Calculators</a>
          <a href="/guides" class="hover:text-blue-600 transition-colors">Guides</a>
        </nav>
      </div>
    </header>
    
    <main class="max-w-5xl mx-auto px-4 py-8">
      <!-- Watermark that only shows when printed -->
      <div class="print-only text-xs text-gray-400 text-center mb-6">
        calcfordiy.com — Free DIY Calculators
      </div>
      
      <slot />
    </main>

    <footer class="border-t border-gray-200 mt-16 px-4 py-8 text-center text-sm text-gray-500">
      <p>© 2026 CalcForDIY — Free calculators for home improvement projects.</p>
      <p class="mt-2">
        <a href="/privacy" class="hover:text-blue-600 mr-4">Privacy Policy</a>
        <a href="/about" class="hover:text-blue-600">About</a>
      </p>
    </footer>

    <!-- Floating results button - added print:hidden so it doesn't print -->
    <div id="floatBtn" class="hidden fixed bottom-6 inset-x-0 flex justify-center z-50 pointer-events-none print:hidden">
      <button
        onclick="document.getElementById('results').scrollIntoView({behavior:'smooth'})"
        class="pointer-events-auto bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-full shadow-xl font-semibold text-sm flex items-center gap-2 transition-all">
        See your results ↓
      </button>
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var resultsEl = document.getElementById('results');
        var floatBtn = document.getElementById('floatBtn');

        if (!resultsEl || !floatBtn) return;

        // Watch results div visibility in viewport
        var intersectionObserver = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (resultsEl.classList.contains('hidden')) {
              floatBtn.classList.add('hidden');
            } else if (entry.isIntersecting) {
              floatBtn.classList.add('hidden');
            } else {
              floatBtn.classList.remove('hidden');
            }
          });
        }, { threshold: 0.1 });

        intersectionObserver.observe(resultsEl);

        // Watch for results div being shown or hidden by calculator JS
        var mutationObserver = new MutationObserver(function () {
          if (resultsEl.classList.contains('hidden')) {
            floatBtn.classList.add('hidden');
          }
        });

        mutationObserver.observe(resultsEl, {
          attributes: true,
          attributeFilter: ['class']
        });
      });
    </script>
  </body>
</html>